# Base / RPC
NEXT_PUBLIC_BASE_CHAIN_ID=
NEXT_PUBLIC_BASE_RPC_URL=

# Supabase
# Fill these from infra/supabase/.env once the local or VM stack is configured.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8050
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
METERING_SUPABASE_URL=http://host.docker.internal:8050

# Contracts
NEXT_PUBLIC_KWHU_TOKEN_ADDRESS=
NEXT_PUBLIC_KWHU_VAULT_ADDRESS=
NEXT_PUBLIC_KWHU_MARKETPLACE_ADDRESS=
NEXT_PUBLIC_KWHU_ENERGY_SETTLEMENT_ADDRESS=

# Metering service
NEXT_PUBLIC_METERING_SERVICE_URL=http://localhost:4100
NEXT_PUBLIC_MQTT_BROKER_URL=mqtts://localhost:8883
METERING_SERVICE_PORT=4100
METERING_SERVICE_ALLOWED_ORIGIN=http://localhost:3000
METERING_OPERATOR_PRIVATE_KEY=

# MQTT / Mosquitto
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=8883
MQTT_DYNSEC_ADMIN_USERNAME=kwhu-admin
MQTT_DYNSEC_ADMIN_PASSWORD=change-me
MQTT_SERVICE_USERNAME=kwhu-metering-service
MQTT_SERVICE_PASSWORD=change-me-too
MQTT_CA_CERT_PATH=/shared/mosquitto/certs/ca.crt

# App
NEXT_PUBLIC_APP_NAME=KWHU MVP
